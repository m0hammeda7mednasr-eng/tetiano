# ═══════════════════════════════════════════════════════════
# Tetiano Inventory System - Backend Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# Supabase Configuration
# ═══════════════════════════════════════════════════════════
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe to expose in frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ CRITICAL: Service role key (NEVER expose in frontend!)
# This key bypasses RLS policies - keep it secret!
# Get it from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════
# Port for the backend server
PORT=3002

# Environment: development | production | staging
NODE_ENV=development

# Frontend URL (for CORS configuration)
# Development: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Backend URL (for OAuth redirects and webhooks)
# Development: http://localhost:3002
# Production: https://your-backend.railway.app
BACKEND_URL=http://localhost:3002
API_URL=http://localhost:3002

# ═══════════════════════════════════════════════════════════
# Shopify OAuth Configuration (Optional)
# ═══════════════════════════════════════════════════════════
# OAuth redirect URI (must match Shopify App settings)
SHOPIFY_REDIRECT_URI=http://localhost:3002/api/shopify/callback

# HTTP timeout for Shopify API calls (milliseconds)
SHOPIFY_HTTP_TIMEOUT_MS=15000

# Webhook secret for HMAC verification (from Shopify App settings)
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret-here

# ═══════════════════════════════════════════════════════════
# Brand-Specific Shopify Configuration (Optional)
# ═══════════════════════════════════════════════════════════
# These are optional - OAuth flow handles credentials dynamically
# Only needed if you want to hardcode specific brand credentials

# Tetiano Brand
SHOPIFY_TETIANO_DOMAIN=tetiano.myshopify.com
SHOPIFY_TETIANO_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_TETIANO_LOCATION_ID=12345678

# 98 Brand
SHOPIFY_98_DOMAIN=98brand.myshopify.com
SHOPIFY_98_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_98_LOCATION_ID=87654321

# ═══════════════════════════════════════════════════════════
# Timezone Configuration
# ═══════════════════════════════════════════════════════════
# Timezone for scheduled jobs (daily reports at 6 PM)
# Options: Africa/Cairo, America/New_York, Europe/London, etc.
TZ=Africa/Cairo

# ═══════════════════════════════════════════════════════════
# CORS Configuration (Optional)
# ═══════════════════════════════════════════════════════════
# Additional allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://example.com,https://another.com

# Regex patterns for allowed origins (comma-separated)
# CORS_ALLOWED_ORIGIN_PATTERNS=^https://.*\.example\.com$

# ═══════════════════════════════════════════════════════════
# Notes:
# ═══════════════════════════════════════════════════════════
# 1. Never commit .env file to git (it's in .gitignore)
# 2. Keep SUPABASE_SERVICE_KEY secret - it has full database access
# 3. In production (Railway), set these in the Variables tab
# 4. Frontend needs separate env vars (VITE_* prefix)
# 5. OAuth flow will store brand credentials in database
